//@version=5
indicator("ICT AMD + FVG", overlay=true, max_boxes_count=200, max_lines_count=200, max_labels_count=200)

// ── Inputs ───────────────────────────────────────────────────────────────────
acc_len      = input.int(10,   "Lookback bars",               group="Accumulation", minval=3)
acc_mult     = input.float(1.5,"Max range (x ATR 14)",        group="Accumulation", minval=0.1, step=0.1)
acc_min      = input.int(5,    "Min bars to confirm",         group="Accumulation", minval=2)
show_fvg     = input.bool(true,  "Show FVGs",                 group="Fair Value Gaps (FEG)")
fvg_ext      = input.int(30,     "Extend bars right",         group="Fair Value Gaps (FEG)", minval=1)
fvg_mitigate = input.bool(true,  "Dim when price enters FVG", group="Fair Value Gaps (FEG)")
c_acc    = input.color(color.new(color.yellow, 85), "Accumulation box",  group="Colours")
c_manip  = input.color(color.new(color.red,     0), "Manipulation",      group="Colours")
c_bull_d = input.color(color.new(color.teal,    0), "Distribution up",   group="Colours")
c_bear_d = input.color(color.new(color.red,    20), "Distribution down", group="Colours")
c_bfvg   = input.color(color.new(color.teal,   80), "Bull FVG",          group="Colours")
c_sfvg   = input.color(color.new(color.red,    80), "Bear FVG",          group="Colours")

// ── ATR + Range ──────────────────────────────────────────────────────────────
atr      = ta.atr(14)
rh       = ta.highest(high, acc_len)
rl       = ta.lowest(low,   acc_len)
is_tight = (rh - rl) <= atr * acc_mult

// ── Accumulation ─────────────────────────────────────────────────────────────
var int   tight_cnt = 0
var float z_high    = na
var float z_low     = na
var int   z_start   = 0
var bool  z_open    = false
var float saved_zh  = na
var float saved_zl  = na

tight_cnt := is_tight ? tight_cnt + 1 : 0
in_acc     = tight_cnt >= acc_min

if in_acc and not in_acc[1]
    z_high  := rh
    z_low   := rl
    z_start := bar_index - tight_cnt + 1
    z_open  := true

if in_acc and z_open
    z_high := math.max(z_high, high)
    z_low  := math.min(z_low,  low)

if not in_acc and in_acc[1] and z_open
    box.new(z_start, z_high, bar_index - 1, z_low, bgcolor=c_acc, border_color=color.new(color.yellow, 40), text=" A", text_size=size.small, text_color=color.new(color.yellow, 0), text_halign=text.align_left, text_valign=text.align_top)
    saved_zh := z_high
    saved_zl := z_low
    z_open   := false

bgcolor(in_acc ? c_acc : na, title="Accumulation (live)")

// ── Manipulation ─────────────────────────────────────────────────────────────
var float mz_high = na
var float mz_low  = na

if not na(saved_zh)
    mz_high  := saved_zh
    mz_low   := saved_zl
    saved_zh := na
    saved_zl := na

bull_m = not in_acc and not na(mz_low)  and low  < mz_low  and close >= mz_low
bear_m = not in_acc and not na(mz_high) and high > mz_high and close <= mz_high

if bull_m or bear_m
    mz_high := na
    mz_low  := na

// ── Distribution ─────────────────────────────────────────────────────────────
var bool wait_bull_d = false
var bool wait_bear_d = false

if bull_m
    wait_bull_d := true
    wait_bear_d := false
if bear_m
    wait_bear_d := true
    wait_bull_d := false

bull_d = wait_bull_d and close > open and (close - open) >= atr * 0.25
bear_d = wait_bear_d and close < open and (open  - close) >= atr * 0.25

if bull_d
    wait_bull_d := false
if bear_d
    wait_bear_d := false

// ── Fair Value Gaps (FEG) ────────────────────────────────────────────────────
bull_fvg_cond = show_fvg and low  > high[2]
bear_fvg_cond = show_fvg and high < low[2]

var box[]   fvg_boxes = array.new<box>()
var bool[]  fvg_bull  = array.new<bool>()
var float[] fvg_top   = array.new<float>()
var float[] fvg_bot   = array.new<float>()

if bull_fvg_cond
    b = box.new(bar_index - 2, low, bar_index + fvg_ext, high[2], bgcolor=c_bfvg, border_color=color.new(color.teal, 50), text=" FVG", text_size=size.tiny, text_color=color.new(color.teal, 20), text_halign=text.align_left)
    array.push(fvg_boxes, b)
    array.push(fvg_bull,  true)
    array.push(fvg_top,   low)
    array.push(fvg_bot,   high[2])

if bear_fvg_cond
    b = box.new(bar_index - 2, low[2], bar_index + fvg_ext, high, bgcolor=c_sfvg, border_color=color.new(color.red, 50), text=" FVG", text_size=size.tiny, text_color=color.new(color.red, 20), text_halign=text.align_left)
    array.push(fvg_boxes, b)
    array.push(fvg_bull,  false)
    array.push(fvg_top,   low[2])
    array.push(fvg_bot,   high)

if fvg_mitigate and array.size(fvg_boxes) > 0
    for i = 0 to array.size(fvg_boxes) - 1
        is_bull   = array.get(fvg_bull, i)
        top_level = array.get(fvg_top,  i)
        bot_level = array.get(fvg_bot,  i)
        b         = array.get(fvg_boxes, i)
        mitigated = is_bull ? low <= top_level : high >= bot_level
        if mitigated
            box.set_bgcolor(b,      color.new(is_bull ? color.teal : color.red, 95))
            box.set_border_color(b, color.new(is_bull ? color.teal : color.red, 80))

// ── Plots ────────────────────────────────────────────────────────────────────
plotshape(bull_m, "Manipulation up",   shape.labelup,   location.belowbar, c_manip,  text="M", textcolor=color.white, size=size.small)
plotshape(bear_m, "Manipulation down", shape.labeldown, location.abovebar, c_manip,  text="M", textcolor=color.white, size=size.small)
plotshape(bull_d, "Distribution up",   shape.arrowup,   location.belowbar, c_bull_d, size=size.normal)
plotshape(bear_d, "Distribution down", shape.arrowdown, location.abovebar, c_bear_d, size=size.normal)
