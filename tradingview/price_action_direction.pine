//@version=5
indicator("Price Action Direction", shorttitle="PAD", overlay=false, max_labels_count=500, max_lines_count=500)

// ─────────────────────────────────────────────
// INPUTS
// ─────────────────────────────────────────────

// Filters
maxSL        = input.float(40.0, "Max Stoploss (points)",      group="Filters", minval=5)
minTarget    = input.float(20.0, "Min Target (points)",         group="Filters", minval=5)
rrRatio      = input.float(2.0,  "Risk:Reward Ratio",           group="Filters", minval=1.0, step=0.5)

// Structure
swingLen     = input.int(5,  "Swing Lookback",                  group="Structure", minval=2, maxval=20)
srLookback   = input.int(20, "S/R Pivot Lookback",              group="Structure", minval=10, maxval=50)
trendBars    = input.int(10, "Trend Strength Lookback",         group="Structure", minval=5, maxval=30)
volLen       = input.int(20, "Volume MA Length",                group="Volume")

// Visual
showSLTP     = input.bool(true, "Show SL/TP Lines",            group="Visual")
lineLen      = input.int(10, "SL/TP Line Length (bars)",        group="Visual", minval=3, maxval=30)

// ─────────────────────────────────────────────
// CORE PRICE DATA
// ─────────────────────────────────────────────

bodySize    = math.abs(close - open)
upperWick   = high - math.max(close, open)
lowerWick   = math.min(close, open) - low
candleRange = high - low
midBody     = (open + close) / 2
atrVal      = ta.atr(14)

isBullBar   = close > open
isBearBar   = close < open

volMA       = ta.sma(volume, volLen)
isVolSpike  = volume >= volMA * 1.5

// Swing levels
swingLo     = ta.lowest(low, swingLen)
swingHi     = ta.highest(high, swingLen)
prevSwingLo = ta.lowest(low, swingLen)[swingLen]
prevSwingHi = ta.highest(high, swingLen)[swingLen]

// ─────────────────────────────────────────────
// 1. HIGHER HIGHS & HIGHER LOWS / LOWER HIGHS & LOWER LOWS
// ─────────────────────────────────────────────

higherHigh = swingHi > prevSwingHi
higherLow  = swingLo > prevSwingLo
lowerHigh  = swingHi < prevSwingHi
lowerLow   = swingLo < prevSwingLo

// Full bullish structure: HH + HL
bullStructure = higherHigh and higherLow
// Full bearish structure: LH + LL
bearStructure = lowerHigh and lowerLow
// Partial
partialBull = higherLow and not lowerLow
partialBear = lowerHigh and not higherHigh

structureScore = bullStructure ? 2 : partialBull ? 1 : bearStructure ? -2 : partialBear ? -1 : 0

// ─────────────────────────────────────────────
// 2. TREND STRENGTH — consecutive closes
// ─────────────────────────────────────────────

// Count recent bullish vs bearish closes
var int bullCount = 0
var int bearCount = 0
bullCount := 0
bearCount := 0

for i = 0 to trendBars - 1
    if close[i] > open[i]
        bullCount += 1
    else if close[i] < open[i]
        bearCount += 1

// Net direction from close bias
trendScore = bullCount > bearCount + 2 ? 2 : bullCount > bearCount ? 1 : bearCount > bullCount + 2 ? -2 : bearCount > bullCount ? -1 : 0

// ─────────────────────────────────────────────
// 3. CLOSING POSITION — where price closes within range
// ─────────────────────────────────────────────

// Close in upper third of recent range = bullish pressure
rangeHigh  = ta.highest(high, trendBars)
rangeLow   = ta.lowest(low, trendBars)
rangeMid   = (rangeHigh + rangeLow) / 2
rangeSize  = rangeHigh - rangeLow

closePosition = rangeSize > 0 ? (close - rangeLow) / rangeSize : 0.5

closePosScore = closePosition > 0.7 ? 2 : closePosition > 0.55 ? 1 : closePosition < 0.3 ? -2 : closePosition < 0.45 ? -1 : 0

// ─────────────────────────────────────────────
// 4. CANDLE MOMENTUM — body size trend
// ─────────────────────────────────────────────

// Are bullish candles getting bigger (momentum building) or bearish candles?
avgBullBody = ta.sma(isBullBar ? bodySize : 0, trendBars)
avgBearBody = ta.sma(isBearBar ? bodySize : 0, trendBars)

// Compare recent body sizes
recentBullBody = ta.sma(isBullBar ? bodySize : 0, 3)
recentBearBody = ta.sma(isBearBar ? bodySize : 0, 3)

bullMomentum = recentBullBody > avgBullBody * 1.2 and recentBullBody > recentBearBody
bearMomentum = recentBearBody > avgBearBody * 1.2 and recentBearBody > recentBullBody

momentumScore = bullMomentum ? 1 : bearMomentum ? -1 : 0

// ─────────────────────────────────────────────
// 5. BREAKOUT DIRECTION
// ─────────────────────────────────────────────

// Breaking above recent range high = bullish, below range low = bearish
breakoutUp   = close > rangeHigh[1] and isBullBar
breakoutDown = close < rangeLow[1] and isBearBar

breakoutScore = breakoutUp ? 2 : breakoutDown ? -2 : 0

// ─────────────────────────────────────────────
// 6. SUPPORT / RESISTANCE BIAS
// ─────────────────────────────────────────────

pivotHi = ta.pivothigh(high, srLookback, srLookback)
pivotLo = ta.pivotlow(low, srLookback, srLookback)

var float resistanceLevel = na
var float supportLevel    = na

if not na(pivotHi)
    resistanceLevel := pivotHi
if not na(pivotLo)
    supportLevel := pivotLo

// Above resistance = bullish breakout bias, below support = bearish breakdown bias
srScore = not na(resistanceLevel) and close > resistanceLevel ? 1 : not na(supportLevel) and close < supportLevel ? -1 : 0

// ─────────────────────────────────────────────
// 7. VOLUME DIRECTION BIAS
// ─────────────────────────────────────────────

// Volume on up candles vs down candles
bullVol = ta.sma(isBullBar ? volume : 0, trendBars)
bearVol = ta.sma(isBearBar ? volume : 0, trendBars)

volDirScore = bullVol > bearVol * 1.3 ? 1 : bearVol > bullVol * 1.3 ? -1 : 0

// ─────────────────────────────────────────────
// TOTAL SCORE
// ─────────────────────────────────────────────

// Max possible: +11 to -11
maxPossible = 11
rawScore = structureScore + trendScore + closePosScore + momentumScore + breakoutScore + srScore + volDirScore

scorePct = math.round(rawScore / maxPossible * 100)

// Direction
isBullish = scorePct >= 30
isBearish = scorePct <= -30

// Seller action
sellerAction = isBullish and isVolSpike ? "SELL PE" : isBearish and isVolSpike ? "SELL CE" : isBullish ? "SELL PE (watch)" : isBearish ? "SELL CE (watch)" : "NO SIGNAL"

// ─────────────────────────────────────────────
// HISTOGRAM
// ─────────────────────────────────────────────

histColor = isBullish and isVolSpike ? color.new(color.green, 10) : isBearish and isVolSpike ? color.new(color.red, 10) : isBullish ? color.new(color.green, 50) : isBearish ? color.new(color.red, 50) : color.new(color.gray, 50)

plot(scorePct, "Score %", style=plot.style_columns, color=histColor, linewidth=2)
hline(0, "Zero", color=color.new(color.white, 60), linestyle=hline.style_dashed)
hline(30, "Bull", color=color.new(color.green, 60), linestyle=hline.style_dotted)
hline(-30, "Bear", color=color.new(color.red, 60), linestyle=hline.style_dotted)

// ─────────────────────────────────────────────
// LABEL ON LAST BAR
// ─────────────────────────────────────────────

signalLabelColor = isBullish ? color.new(color.green, 0) : isBearish ? color.new(color.red, 0) : color.new(color.gray, 0)
signalLabelText = isBullish ? "BULLISH" : isBearish ? "BEARISH" : "NEUTRAL"

var label sigLabel = na
if barstate.islast
    label.delete(sigLabel)
    sigLabel := label.new(bar_index, scorePct, signalLabelText + "\n" + sellerAction + "  [" + str.tostring(scorePct) + "%]", style=label.style_label_left, color=signalLabelColor, textcolor=color.white, size=size.normal)

// ─────────────────────────────────────────────
// STOPLOSS & TARGET
// ─────────────────────────────────────────────

bullSL     = swingLo - 2
bullEntry  = close
bullSLdist = bullEntry - bullSL
bullTP     = bullEntry + bullSLdist * rrRatio

bearSL     = swingHi + 2
bearEntry  = close
bearSLdist = bearSL - bearEntry
bearTP     = bearEntry - bearSLdist * rrRatio

// ─────────────────────────────────────────────
// ENTRY / EXIT ON MAIN CHART
// ─────────────────────────────────────────────

regime = isBullish ? 1 : isBearish ? -1 : 0
prevRegime = nz(regime[1], 0)

rawEntryPE = (regime == 1) and (prevRegime != 1)
rawEntryCE = (regime == -1) and (prevRegime != -1)

// Filter by SL/TP
entryPE = rawEntryPE and bullSLdist > 0 and bullSLdist <= maxSL and (bullTP - bullEntry) >= minTarget
entryCE = rawEntryCE and bearSLdist > 0 and bearSLdist <= maxSL and (bearEntry - bearTP) >= minTarget

if entryPE
    label.new(bar_index, low, "PE", style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white, size=size.small, force_overlay=true)
if entryCE
    label.new(bar_index, high, "CE", style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small, force_overlay=true)

// SL/TP lines on main chart
if showSLTP and entryPE
    line.new(bar_index, bullEntry, bar_index + lineLen, bullEntry, color=color.new(color.green, 0), style=line.style_solid, width=1, force_overlay=true)
    line.new(bar_index, bullSL, bar_index + lineLen, bullSL, color=color.new(color.red, 0), style=line.style_dashed, width=1, force_overlay=true)
    line.new(bar_index, bullTP, bar_index + lineLen, bullTP, color=color.new(color.blue, 0), style=line.style_dashed, width=1, force_overlay=true)
    label.new(bar_index + lineLen, bullSL, "SL " + str.tostring(math.round(bullSLdist, 1)), style=label.style_none, textcolor=color.new(color.red, 0), size=size.tiny, force_overlay=true)
    label.new(bar_index + lineLen, bullTP, "TP " + str.tostring(math.round(bullTP - bullEntry, 1)), style=label.style_none, textcolor=color.new(color.blue, 0), size=size.tiny, force_overlay=true)

if showSLTP and entryCE
    line.new(bar_index, bearEntry, bar_index + lineLen, bearEntry, color=color.new(color.red, 0), style=line.style_solid, width=1, force_overlay=true)
    line.new(bar_index, bearSL, bar_index + lineLen, bearSL, color=color.new(color.red, 0), style=line.style_dashed, width=1, force_overlay=true)
    line.new(bar_index, bearTP, bar_index + lineLen, bearTP, color=color.new(color.blue, 0), style=line.style_dashed, width=1, force_overlay=true)
    label.new(bar_index + lineLen, bearSL, "SL " + str.tostring(math.round(bearSLdist, 1)), style=label.style_none, textcolor=color.new(color.red, 0), size=size.tiny, force_overlay=true)
    label.new(bar_index + lineLen, bearTP, "TP " + str.tostring(math.round(bearEntry - bearTP, 1)), style=label.style_none, textcolor=color.new(color.blue, 0), size=size.tiny, force_overlay=true)

// ─────────────────────────────────────────────
// SCORE BREAKDOWN TABLE (top-right, on main chart)
// ─────────────────────────────────────────────

scoreColor(s) =>
    s >= 2 ? color.new(color.green, 0) : s == 1 ? color.new(color.green, 40) : s <= -2 ? color.new(color.red, 0) : s == -1 ? color.new(color.red, 40) : color.new(color.gray, 40)

scoreLabel(s) =>
    result = ""
    if s >= 2
        result := "Strong ▲"
    else if s == 1
        result := "▲"
    else if s <= -2
        result := "Strong ▼"
    else if s == -1
        result := "▼"
    else
        result := "—"
    result

var table scoreTable = na
if barstate.islast
    table.delete(scoreTable)
    scoreTable := table.new(position.top_right, 3, 11, bgcolor=color.new(color.black, 75), border_color=color.new(color.white, 60), border_width=1, frame_color=color.new(color.white, 40), frame_width=1, force_overlay=true)

    table.cell(scoreTable, 0, 0, "Price Action Direction", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 50))
    table.cell(scoreTable, 1, 0, "Signal", text_color=color.new(color.white, 20), text_size=size.small, bgcolor=color.new(color.black, 50))
    table.cell(scoreTable, 2, 0, "Score", text_color=color.new(color.white, 20), text_size=size.small, bgcolor=color.new(color.black, 50))

    // 1 — Structure
    sLabel = bullStructure ? "HH + HL" : partialBull ? "HL" : bearStructure ? "LH + LL" : partialBear ? "LH" : "Flat"
    table.cell(scoreTable, 0, 1, "Structure", text_color=color.white, text_size=size.small)
    table.cell(scoreTable, 1, 1, sLabel, text_color=scoreColor(structureScore), text_size=size.small)
    table.cell(scoreTable, 2, 1, str.tostring(structureScore), text_color=scoreColor(structureScore), text_size=size.small)

    // 2 — Trend
    tLabel = str.tostring(bullCount) + "B / " + str.tostring(bearCount) + "S"
    table.cell(scoreTable, 0, 2, "Trend (" + str.tostring(trendBars) + ")", text_color=color.white, text_size=size.small)
    table.cell(scoreTable, 1, 2, tLabel, text_color=scoreColor(trendScore), text_size=size.small)
    table.cell(scoreTable, 2, 2, str.tostring(trendScore), text_color=scoreColor(trendScore), text_size=size.small)

    // 3 — Close Position
    cpLabel = str.tostring(math.round(closePosition * 100)) + "%"
    table.cell(scoreTable, 0, 3, "Close Position", text_color=color.white, text_size=size.small)
    table.cell(scoreTable, 1, 3, cpLabel, text_color=scoreColor(closePosScore), text_size=size.small)
    table.cell(scoreTable, 2, 3, str.tostring(closePosScore), text_color=scoreColor(closePosScore), text_size=size.small)

    // 4 — Momentum
    mLabel = bullMomentum ? "Bull bodies ▲" : bearMomentum ? "Bear bodies ▼" : "Even"
    table.cell(scoreTable, 0, 4, "Momentum", text_color=color.white, text_size=size.small)
    table.cell(scoreTable, 1, 4, mLabel, text_color=scoreColor(momentumScore), text_size=size.small)
    table.cell(scoreTable, 2, 4, str.tostring(momentumScore), text_color=scoreColor(momentumScore), text_size=size.small)

    // 5 — Breakout
    bkLabel = breakoutUp ? "Break ▲" : breakoutDown ? "Break ▼" : "In range"
    table.cell(scoreTable, 0, 5, "Breakout", text_color=color.white, text_size=size.small)
    table.cell(scoreTable, 1, 5, bkLabel, text_color=scoreColor(breakoutScore), text_size=size.small)
    table.cell(scoreTable, 2, 5, str.tostring(breakoutScore), text_color=scoreColor(breakoutScore), text_size=size.small)

    // 6 — S/R
    srLabel = srScore == 1 ? "Above Resist" : srScore == -1 ? "Below Support" : "Between"
    table.cell(scoreTable, 0, 6, "S/R Bias", text_color=color.white, text_size=size.small)
    table.cell(scoreTable, 1, 6, srLabel, text_color=scoreColor(srScore), text_size=size.small)
    table.cell(scoreTable, 2, 6, str.tostring(srScore), text_color=scoreColor(srScore), text_size=size.small)

    // 7 — Volume Direction
    vdLabel = volDirScore == 1 ? "Bull vol ▲" : volDirScore == -1 ? "Bear vol ▼" : "Even"
    table.cell(scoreTable, 0, 7, "Vol Direction", text_color=color.white, text_size=size.small)
    table.cell(scoreTable, 1, 7, vdLabel, text_color=scoreColor(volDirScore), text_size=size.small)
    table.cell(scoreTable, 2, 7, str.tostring(volDirScore), text_color=scoreColor(volDirScore), text_size=size.small)

    // Separator
    table.cell(scoreTable, 0, 8, "", text_size=size.small, bgcolor=color.new(color.black, 50))
    table.cell(scoreTable, 1, 8, "", text_size=size.small, bgcolor=color.new(color.black, 50))
    table.cell(scoreTable, 2, 8, "", text_size=size.small, bgcolor=color.new(color.black, 50))

    // Result
    resultBg = isBullish ? color.new(color.green, 40) : isBearish ? color.new(color.red, 40) : color.new(color.gray, 60)
    table.cell(scoreTable, 0, 9, sellerAction, text_color=color.white, text_size=size.normal, bgcolor=resultBg)
    table.cell(scoreTable, 1, 9, signalLabelText, text_color=color.white, text_size=size.normal, bgcolor=resultBg)
    table.cell(scoreTable, 2, 9, str.tostring(scorePct) + "%", text_color=color.white, text_size=size.normal, bgcolor=resultBg)

    // Range info
    table.cell(scoreTable, 0, 10, "Range", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 50))
    table.cell(scoreTable, 1, 10, str.tostring(math.round(rangeLow, 1)) + " — " + str.tostring(math.round(rangeHigh, 1)), text_color=color.new(color.white, 40), text_size=size.small, bgcolor=color.new(color.black, 50))
    table.cell(scoreTable, 2, 10, str.tostring(math.round(rangeSize, 1)) + "pts", text_color=color.new(color.white, 40), text_size=size.small, bgcolor=color.new(color.black, 50))

// ─────────────────────────────────────────────
// ALERTS
// ─────────────────────────────────────────────

alertcondition(entryPE, "Bullish — Sell PE", "PAD → Bullish direction, sell PE")
alertcondition(entryCE, "Bearish — Sell CE", "PAD → Bearish direction, sell CE")
