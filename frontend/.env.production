# Production environment. Do NOT put secrets here.

VITE_API_URL=https://kaiterminal.com

VITE_APP_NAME=KAI Terminal
VITE_UPSTOX_OAUTH_URL=https://api.upstox.com/v2/login/authorization/dialog
VITE_ZERODHA_OAUTH_URL=https://kite.zerodha.com/connect/login

# Profit protection defaults (user-adjustable in app)
VITE_PP_MTM_TARGET=25000
VITE_PP_MTM_SL=-25000
VITE_PP_TRAILING_ENABLED=true
VITE_PP_TRAILING_ACTIVATE_AT=10000
VITE_PP_LOCK_PROFIT_AT=3000
VITE_PP_INCREASE_BY=100
VITE_PP_TRAIL_BY=50
