# Backend API base URL — must match the running KAITerminal.Api address.
VITE_API_URL=https://localhost:5001

# App display name
VITE_APP_NAME=KAI Terminal

# Upstox OAuth authorization URL
VITE_UPSTOX_OAUTH_URL=https://api.upstox.com/v2/login/authorization/dialog

# Profit protection defaults
VITE_PP_MTM_TARGET=25000
VITE_PP_MTM_SL=-25000
VITE_PP_TRAILING_ENABLED=true
VITE_PP_TRAILING_ACTIVATE_AT=12000
VITE_PP_LOCK_PROFIT_AT=2000
VITE_PP_INCREASE_BY=99
VITE_PP_TRAIL_BY=33
